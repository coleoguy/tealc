data/voice_index_st.npz
data/voice_sentences.jsonl
data/scheduler.pid
data/scheduler_heartbeat.json
data/dashboard_server.pid
data/scheduler.stdout.log
data/dashboard_server.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# macOS / editor
.DS_Store
.vscode/
.idea/
*.swp
