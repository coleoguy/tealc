# Secrets — never commit
.env
.env.*
google_credentials.json
data/google_token.json

# Runtime SQLite DB (canonical lives at ~/Library/Application Support/tealc/agent.db)
data/agent.db
data/agent.db-shm
data/agent.db-wal

# Regenerable caches (rebuilt by jobs / scheduler)
